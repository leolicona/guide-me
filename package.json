{
  "name": "turistear-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for the Turistear Ya! application and API services",
  "scripts": {
    "dev:api": "pnpm --filter api-turistear dev",
    "dev:app": "pnpm --filter app-turistear dev",
    "build:api": "pnpm --filter api-turistear build",
    "build:app": "pnpm --filter app-turistear build",
    "deploy:api": "pnpm --filter api-turistear run deploy",
    "deploy:app": "pnpm --filter app-turistear run deploy",
    "cf-typegen:api": "pnpm --filter api-turistear cf-typegen",
    "cf-typegen:app": "pnpm --filter app-turistear cf-typegen",
    "lint:app": "pnpm --filter app-turistear lint",
    "dev": "pnpm --parallel dev",
    "test:api": "pnpm --filter api-turistear test",
    "db:migrate:local": "pnpm --filter api-turistear db:migrate:local",
    "db:migrate": "pnpm --filter api-turistear db:migrate",
    "db:generate": "pnpm --filter api-turistear db:generate"
  }
}
